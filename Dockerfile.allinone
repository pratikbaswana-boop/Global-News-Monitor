## ============================================================================
## All-in-one image: Postgres + Neo4j + ChromaDB + API server + frontend + nginx
## supervised by supervisord. Built for single-service hosts like Railway.
##
##   - Exposes port 80 only (nginx serves frontend, proxies /api → api-server)
##   - Persists state under /data (mount one volume here on Railway)
##   - One env var to set:  OPENAI_API_KEY  (+ any news API keys you have)
## ============================================================================

## ── Stage 1: build frontend ─────────────────────────────────────────────────
FROM node:24-bookworm-slim AS frontend-build
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /repo

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json tsconfig.json ./
COPY artifacts/global-news/package.json    artifacts/global-news/
COPY artifacts/global-news/tsconfig.json   artifacts/global-news/
COPY artifacts/global-news/vite.config.ts  artifacts/global-news/
COPY artifacts/global-news/components.json artifacts/global-news/
COPY artifacts/global-news/index.html      artifacts/global-news/
COPY lib/api-client-react/package.json     lib/api-client-react/
COPY lib/api-zod/package.json              lib/api-zod/
COPY lib/db/package.json                   lib/db/
COPY lib/integrations-openai-ai-server/package.json lib/integrations-openai-ai-server/
COPY lib/api-spec/package.json             lib/api-spec/
COPY artifacts/api-server/package.json     artifacts/api-server/
COPY scripts/package.json                  scripts/

ENV CI=true
RUN pnpm install --filter "@workspace/global-news..." --frozen-lockfile --config.minimum-release-age=0

COPY lib lib
COPY artifacts/global-news/src    artifacts/global-news/src
COPY artifacts/global-news/public artifacts/global-news/public
COPY attached_assets              attached_assets

ENV PORT=80 BASE_PATH=/ NODE_ENV=production
RUN pnpm --filter @workspace/global-news run build


## ── Stage 2: build api-server ───────────────────────────────────────────────
FROM node:24-bookworm-slim AS api-build
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /repo

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json tsconfig.json ./
COPY artifacts/api-server/package.json     artifacts/api-server/
COPY artifacts/api-server/build.mjs        artifacts/api-server/
COPY artifacts/api-server/tsconfig.json    artifacts/api-server/
COPY lib/api-zod/package.json              lib/api-zod/
COPY lib/api-client-react/package.json     lib/api-client-react/
COPY lib/api-spec/package.json             lib/api-spec/
COPY lib/db/package.json                   lib/db/
COPY lib/integrations-openai-ai-server/package.json lib/integrations-openai-ai-server/
COPY scripts/package.json                  scripts/

ENV CI=true
RUN pnpm install --filter "@workspace/api-server..." --frozen-lockfile --config.minimum-release-age=0

COPY lib  lib
COPY artifacts/api-server/src artifacts/api-server/src
RUN pnpm --filter @workspace/api-server run build


## ── Stage 3: stage migration tool ──────────────────────────────────────────
FROM node:24-bookworm-slim AS migrate-build
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /repo

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json tsconfig.json ./
COPY lib/db/package.json     lib/db/
COPY lib/db/drizzle.config.ts lib/db/
COPY lib/db/tsconfig.json    lib/db/
COPY lib/db/src              lib/db/src

ENV CI=true
RUN pnpm install --filter "@workspace/db..." --frozen-lockfile --config.minimum-release-age=0


## ── Stage 4: runtime ────────────────────────────────────────────────────────
FROM debian:bookworm-slim AS runtime

ENV DEBIAN_FRONTEND=noninteractive

# Base utilities + add the official PostgreSQL apt repo (Debian default is PG15; we want PG16)
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg wget tini supervisor nginx \
        openjdk-17-jre-headless \
        python3 python3-pip python3-venv \
        procps net-tools \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc | gpg --dearmor -o /usr/share/keyrings/postgresql.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/postgresql.gpg] http://apt.postgresql.org/pub/repos/apt bookworm-pgdg main" > /etc/apt/sources.list.d/pgdg.list \
    && apt-get update && apt-get install -y --no-install-recommends \
        postgresql-16 postgresql-contrib-16 \
    && rm -rf /var/lib/apt/lists/*

# Node.js 24
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Neo4j 5 (Debian package, community edition)
RUN curl -fsSL https://debian.neo4j.com/neotechnology.gpg.key | gpg --dearmor -o /usr/share/keyrings/neo4j.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/neo4j.gpg] https://debian.neo4j.com stable 5" > /etc/apt/sources.list.d/neo4j.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends neo4j=1:5.26.0 \
    && rm -rf /var/lib/apt/lists/*

# ChromaDB (Python) — server-only, no heavy ML deps
RUN python3 -m venv /opt/chroma \
    && /opt/chroma/bin/pip install --no-cache-dir chromadb==0.5.23

# Disable default nginx site
RUN rm -f /etc/nginx/sites-enabled/default

# Make /var/log/neo4j writable by the neo4j user (the Debian package's
# log4j config writes here even though our data lives in /data/neo4j)
RUN mkdir -p /var/log/neo4j && chown -R neo4j:neo4j /var/log/neo4j

# ── Bundle artifacts ───────────────────────────────────────────────────────
WORKDIR /app

# Frontend static files
COPY --from=frontend-build /repo/artifacts/global-news/dist/public /usr/share/nginx/html

# API server bundle
COPY --from=api-build /repo/artifacts/api-server/dist /app/api/dist

# Migration tool (drizzle-kit + lib/db) — full workspace tree for path resolution
COPY --from=migrate-build /repo /app/migrate

# Config files
COPY deploy/allinone/nginx.conf        /etc/nginx/conf.d/gnm.conf
COPY deploy/allinone/supervisord.conf  /etc/supervisor/conf.d/gnm.conf
COPY deploy/allinone/entrypoint.sh     /entrypoint.sh
COPY deploy/allinone/run-neo4j.sh      /usr/local/bin/run-neo4j.sh
COPY deploy/allinone/postgres-tune.conf /etc/postgresql/16/main/conf.d/tune.conf
RUN chmod +x /entrypoint.sh /usr/local/bin/run-neo4j.sh

# ── Runtime config ─────────────────────────────────────────────────────────
ENV NODE_ENV=production \
    PORT=3000 \
    DATA_DIR=/data \
    PGDATA=/data/pg \
    PGUSER=gnm \
    PGDATABASE=gnm \
    NEO4J_HOME=/var/lib/neo4j \
    NEO4J_DATA=/data/neo4j \
    CHROMA_PATH=/data/chroma \
    LLM_PROVIDER=openai \
    LLM_MODEL_CHAT=gpt-4o-mini \
    LLM_MODEL_EMBED=text-embedding-3-small \
    AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1 \
    NEO4J_URI=bolt://127.0.0.1:7687 \
    NEO4J_USER=neo4j \
    CHROMADB_HOST=127.0.0.1 \
    CHROMADB_PORT=8000 \
    ADMIN_SECRET=please_override_in_env \
    LOG_LEVEL=info \
    NEWS_FETCH_INTERVAL_HOURS=1

# Single port: nginx fronts everything
EXPOSE 80

# Persistent state lives here. Mount a Railway volume at this path.
VOLUME ["/data"]

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
CMD ["/usr/bin/supervisord", "-n", "-c", "/etc/supervisor/supervisord.conf"]
