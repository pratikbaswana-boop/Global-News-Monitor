# =============================================================================
# Production environment template
# Copy to .env.production and fill in your values. Never commit .env.production.
# =============================================================================

# Public host. If you have a domain pointed at this server, set it here and
# Caddy will auto-issue HTTPS certs (Let's Encrypt). Leave as ":80" for HTTP-only
# bring-up on a fresh box without DNS yet.
DOMAIN=:80
# Example for production with a real domain:
# DOMAIN=intel.example.com

# ── LLM provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL_CHAT=gpt-4o-mini
LLM_MODEL_EMBED=text-embedding-3-small

OPENAI_API_KEY=sk-CHANGE_ME
# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Override if you proxy OpenAI through e.g. OpenRouter
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Databases (internal docker network — passwords still required) ───────────
POSTGRES_USER=gnm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gnm

NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── News ingestion API keys ──────────────────────────────────────────────────
NEWSAPI_KEY=
GNEWS_KEY=
GUARDIAN_KEY=
ACLED_API_KEY=
ACLED_EMAIL=
NEWS_FETCH_INTERVAL_HOURS=1

# ── Push notifications (auto-generated on first run if blank) ────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NOTIFICATION_WEBHOOK_URL=

# ── Admin / ops ──────────────────────────────────────────────────────────────
ADMIN_SECRET=CHANGE_ME_LONG_RANDOM_STRING
LOG_LEVEL=info
